# ──────────────────────────────────────────────────────
# CodeForge AI — Node API environment variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────────────

# MongoDB Atlas connection string (required for data persistence)
# Without this, API runs in offline mode (empty data, no crash)
MONGODB_URL=mongodb+srv://USER:PASS@cluster.mongodb.net
MONGODB_DB=codeforge

# AI API keys (at least one required for AI features)
OPENROUTER_API_KEY=sk-or-v1-...
GROQ_API_KEY=gsk_...

# GitHub OAuth App (required for GitHub login)
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Session signing secret — any random 32+ char string
SESSION_SECRET=change-me-to-a-random-32-char-string

# Frontend URL — where your browser opens the app (OAuth redirects here after login)
# IMPORTANT: Must match where your frontend dev server is running
FRONTEND_URL=http://localhost:5173

# Node API port
PORT=3000
