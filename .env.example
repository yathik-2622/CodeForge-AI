# ─── CodeForge AI — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git!

# ── AI Providers ─────────────────────────────────────────────────────────────
# OpenRouter — 11 free models (Mistral, Llama, DeepSeek, Gemma, Qwen, etc.)
# Get your free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Groq — 7 free models with ultra-fast inference (Llama, Mixtral, Gemma, DeepSeek)
# Get your free key at: https://console.groq.com/keys
# OPTIONAL — leave empty to disable Groq models
GROQ_API_KEY=gsk_...

# ── Database ─────────────────────────────────────────────────────────────────
# MongoDB connection string (local or MongoDB Atlas free tier)
# Local:  mongodb://127.0.0.1:27017/codeforge
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/codeforge
MONGODB_URL=mongodb://127.0.0.1:27017/codeforge
MONGODB_DB=codeforge

# ── GitHub OAuth (for repository linking) ────────────────────────────────────
# Create an OAuth App at: https://github.com/settings/developers
# Homepage URL:        http://localhost:3000
# Callback URL:        http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Session Security ─────────────────────────────────────────────────────────
# Any long random string — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-use-openssl-rand-hex-32

# ── Optional Integrations ────────────────────────────────────────────────────
# Tavily — web search in AI sessions (free tier: 1000 searches/month)
# https://tavily.com
TAVILY_API_KEY=

# Twilio — WhatsApp integration (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Qdrant — vector search for repository analysis (optional)
# https://cloud.qdrant.io (free tier available)
QDRANT_URL=
QDRANT_API_KEY=

# ── node_api config ───────────────────────────────────────────────────────────
PORT=3000
APP_URL=http://localhost:3000

# ── backend (Python FastAPI) config ──────────────────────────────────────────
BACKEND_PORT=9000
