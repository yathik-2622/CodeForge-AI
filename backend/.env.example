# ─────────────────────────────────────────────────────────────────────────────
# CodeForge AI — Backend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Random secret for signing JWT tokens (min 32 characters)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=your-32-character-random-secret-here

# OpenRouter API key — free AI models (Mistral, Llama, Phi, Gemma)
# Get free key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# MongoDB connection string
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/codeforge
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=codeforge

# ── QDRANT VECTOR SEARCH ─────────────────────────────────────────────────────
# Leave empty to use fast in-memory mode (data lost on restart)
# Qdrant Cloud: https://cloud.qdrant.io (free tier available)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=codeforge_repos

# ── GITHUB OAUTH LOGIN ────────────────────────────────────────────────────────
# Create OAuth App: https://github.com/settings/developers
# Callback URL: http://localhost:9000/api/auth/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# App URLs (update for production deployment)
APP_URL=http://localhost:9000
FRONTEND_URL=http://localhost:5173

# ── TAVILY WEB SEARCH ─────────────────────────────────────────────────────────
# Free: 1,000 searches/month — https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# ── AI MODEL SETTINGS ─────────────────────────────────────────────────────────
# Free models via OpenRouter:
#   mistralai/mistral-7b-instruct:free   (default, fast)
#   meta-llama/llama-3-8b-instruct:free  (good for code)
#   microsoft/phi-3-mini-128k-instruct:free (huge context)
#   google/gemma-3-12b-it:free           (strong reasoning)
AI_MODEL=mistralai/mistral-7b-instruct:free
AI_TEMPERATURE=0.2
MAX_TOKENS=4096

# ── TWILIO (OPTIONAL) — WhatsApp + Instagram DMs ─────────────────────────────
# Sign up free: https://twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_INSTAGRAM_FROM=your-instagram-page-id

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
