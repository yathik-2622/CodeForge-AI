# =============================================================================
# CodeForge AI — Backend Environment Variables
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below
#   3. Never commit your .env file to git!
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Python API server listens on (do not change unless you know why)
PORT=9000
# Allowed frontend origin for CORS (your frontend URL)
FRONTEND_URL=http://localhost:5173
# Your deployed app URL (used in OAuth callbacks and webhooks)
APP_URL=http://localhost:9000

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED: A long random string (at least 32 characters)
# Generate one:  python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-this-to-a-long-random-secret-minimum-32-chars

# ── AI (OpenRouter — Free Models) ────────────────────────────────────────────
# Get your free API key at: https://openrouter.ai/keys
# Free models available: mistral-7b, llama-3-8b, phi-3-mini, gemma-3-12b
OPENROUTER_API_KEY=sk-or-your-key-here
# Default model to use (change to any free model from openrouter.ai)
DEFAULT_MODEL=mistralai/mistral-7b-instruct:free

# ── Database: MongoDB ─────────────────────────────────────────────────────────
# Local MongoDB:  mongodb://localhost:27017
# MongoDB Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=codeforge

# ── Vector Store: Qdrant ──────────────────────────────────────────────────────
# Local Qdrant (Docker):  http://localhost:6333
# Qdrant Cloud:           https://xyz.qdrant.io:6333
# Leave empty to use in-memory mode (no persistence, good for dev)
QDRANT_URL=http://localhost:6333
# Optional API key for Qdrant Cloud
QDRANT_API_KEY=

# ── GitHub OAuth (for "Sign in with GitHub") ─────────────────────────────────
# Create at: https://github.com/settings/developers → New OAuth App
# Callback URL must be: http://localhost:9000/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── Web Search: Tavily ────────────────────────────────────────────────────────
# Get free key (1000 searches/month) at: https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# ── WhatsApp Integration (Twilio) ─────────────────────────────────────────────
# Create free account at: https://twilio.com
# Enable WhatsApp Sandbox in: Console → Messaging → Try it out
# Set webhook URL to: http://your-app.com/api/whatsapp/webhook
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Instagram Integration (Twilio) ────────────────────────────────────────────
# Enable Instagram in Twilio Console → Messaging → Channels → Instagram
# Set webhook URL to: http://your-app.com/api/instagram/webhook
TWILIO_INSTAGRAM_FROM=instagram:your-page-id
