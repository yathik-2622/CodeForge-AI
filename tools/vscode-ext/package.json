{
  "name": "codeforge-ai",
  "displayName": "CodeForge AI",
  "description": "Autonomous AI coding agent — chat, explain, fix, and generate code directly in VS Code",
  "version": "1.0.0",
  "publisher": "codeforge",
  "icon": "media/icon.png",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Chat", "Programming Languages", "Other"],
  "keywords": ["ai", "coding", "agent", "autocomplete", "openrouter", "llm", "github"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "CodeForge AI",
      "properties": {
        "codeforge.serverUrl": {
          "type": "string",
          "default": "https://your-codeforge-app.replit.app",
          "description": "URL of your CodeForge AI server"
        },
        "codeforge.model": {
          "type": "string",
          "default": "mistralai/mistral-7b-instruct:free",
          "enum": [
            "mistralai/mistral-7b-instruct:free",
            "meta-llama/llama-3-8b-instruct:free",
            "microsoft/phi-3-mini-128k-instruct:free",
            "google/gemma-3-12b-it:free"
          ],
          "description": "AI model to use"
        },
        "codeforge.autoScan": {
          "type": "boolean",
          "default": true,
          "description": "Automatically include open file context in AI requests"
        }
      }
    },
    "commands": [
      {
        "command": "codeforge.openChat",
        "title": "Open Chat",
        "category": "CodeForge AI",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "codeforge.sendSelection",
        "title": "Send Selection to AI",
        "category": "CodeForge AI",
        "icon": "$(send)"
      },
      {
        "command": "codeforge.explainCode",
        "title": "Explain Selected Code",
        "category": "CodeForge AI",
        "icon": "$(question)"
      },
      {
        "command": "codeforge.fixCode",
        "title": "Fix Selected Code",
        "category": "CodeForge AI",
        "icon": "$(wrench)"
      },
      {
        "command": "codeforge.generateTests",
        "title": "Generate Tests for Selection",
        "category": "CodeForge AI",
        "icon": "$(beaker)"
      },
      {
        "command": "codeforge.newSession",
        "title": "New Session",
        "category": "CodeForge AI",
        "icon": "$(add)"
      },
      {
        "command": "codeforge.setServer",
        "title": "Set Server URL",
        "category": "CodeForge AI"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeforge-sidebar",
          "title": "CodeForge AI",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "codeforge-sidebar": [
        {
          "type": "webview",
          "id": "codeforge.chatView",
          "name": "Chat",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "submenu": "codeforge.submenu",
          "group": "codeforge"
        }
      ],
      "codeforge.submenu": [
        { "command": "codeforge.explainCode", "group": "1_explain" },
        { "command": "codeforge.fixCode", "group": "1_explain" },
        { "command": "codeforge.generateTests", "group": "1_explain" },
        { "command": "codeforge.sendSelection", "group": "2_send" }
      ],
      "view/title": [
        {
          "command": "codeforge.newSession",
          "when": "view == codeforge.chatView",
          "group": "navigation"
        }
      ]
    },
    "submenus": [
      {
        "id": "codeforge.submenu",
        "label": "CodeForge AI"
      }
    ],
    "keybindings": [
      {
        "command": "codeforge.openChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "codeforge.explainCode",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      },
      {
        "command": "codeforge.fixCode",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "editorHasSelection"
      }
    ]
  },
  "scripts": {
    "compile": "webpack --mode development",
    "build": "webpack --mode production",
    "package": "vsce package --no-dependencies",
    "watch": "webpack --mode development --watch"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  }
}
