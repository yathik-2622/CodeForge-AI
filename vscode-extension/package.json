{
  "name": "codeforge-ai",
  "displayName": "CodeForge AI",
  "description": "Autonomous AI coding agent — like Cursor + Claude Code in one extension. Chat, refactor, search the web, deploy — all from VS Code.",
  "version": "0.1.0",
  "publisher": "codeforge-ai",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/yathik-2622/CodeForge-AI"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Programming Languages", "Other"],
  "keywords": ["ai", "coding", "agent", "llm", "copilot", "chat", "refactor", "autonomous"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      { "command": "codeforge.openChat", "title": "CodeForge: Open Chat", "icon": "$(comment-discussion)" },
      { "command": "codeforge.askAboutSelection", "title": "CodeForge: Ask About Selection", "icon": "$(lightbulb)" },
      { "command": "codeforge.fixSelection", "title": "CodeForge: Fix This Code", "icon": "$(wrench)" },
      { "command": "codeforge.explainSelection", "title": "CodeForge: Explain Selection", "icon": "$(info)" },
      { "command": "codeforge.generateTests", "title": "CodeForge: Generate Tests", "icon": "$(beaker)" },
      { "command": "codeforge.refactorSelection", "title": "CodeForge: Refactor Selection", "icon": "$(symbol-misc)" },
      { "command": "codeforge.searchWeb", "title": "CodeForge: Search Web", "icon": "$(search)" },
      { "command": "codeforge.newSession", "title": "CodeForge: New Session", "icon": "$(add)" },
      { "command": "codeforge.openDashboard", "title": "CodeForge: Open Dashboard", "icon": "$(dashboard)" }
    ],
    "menus": {
      "editor/context": [
        { "command": "codeforge.askAboutSelection", "when": "editorHasSelection", "group": "codeforge@1" },
        { "command": "codeforge.fixSelection", "when": "editorHasSelection", "group": "codeforge@2" },
        { "command": "codeforge.explainSelection", "when": "editorHasSelection", "group": "codeforge@3" },
        { "command": "codeforge.generateTests", "when": "editorHasSelection", "group": "codeforge@4" },
        { "command": "codeforge.refactorSelection", "when": "editorHasSelection", "group": "codeforge@5" }
      ],
      "editor/title": [
        { "command": "codeforge.openChat", "group": "navigation" }
      ]
    },
    "keybindings": [
      { "command": "codeforge.openChat", "key": "ctrl+shift+a", "mac": "cmd+shift+a" },
      { "command": "codeforge.askAboutSelection", "key": "ctrl+shift+q", "mac": "cmd+shift+q", "when": "editorHasSelection" },
      { "command": "codeforge.fixSelection", "key": "ctrl+shift+f", "mac": "cmd+shift+f", "when": "editorHasSelection" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeforge",
          "title": "CodeForge AI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codeforge": [
        { "type": "webview", "id": "codeforge.chatView", "name": "Chat", "icon": "$(comment-discussion)" },
        { "type": "webview", "id": "codeforge.sessionsView", "name": "Sessions", "icon": "$(list-unordered)" }
      ]
    },
    "configuration": {
      "title": "CodeForge AI",
      "properties": {
        "codeforge.serverUrl": {
          "type": "string",
          "default": "https://dcbd7002-75e6-4b74-876b-cab38e367e7f-00-3bbkbsikwn73z.pike.replit.dev",
          "description": "CodeForge AI server URL (your Replit or self-hosted deployment)"
        },
        "codeforge.model": {
          "type": "string",
          "default": "mistralai/mistral-7b-instruct:free",
          "enum": [
            "mistralai/mistral-7b-instruct:free",
            "meta-llama/llama-3-8b-instruct:free",
            "microsoft/phi-3-mini-128k-instruct:free",
            "google/gemma-3-12b-it:free"
          ],
          "enumDescriptions": [
            "Mistral 7B — Fast, great for code (Free)",
            "Llama 3 8B — Open source, well-rounded (Free)",
            "Phi-3 Mini — 128k context window (Free)",
            "Gemma 3 12B — Google's model (Free)"
          ],
          "description": "AI model to use for responses"
        },
        "codeforge.includeFileContext": {
          "type": "boolean",
          "default": true,
          "description": "Automatically include current file content in AI requests"
        },
        "codeforge.streamResponses": {
          "type": "boolean",
          "default": true,
          "description": "Stream AI responses token by token"
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run compile -- --watch",
    "package": "vsce package",
    "publish": "vsce publish",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
