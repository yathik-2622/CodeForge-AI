{
  "name": "codeforge",
  "version": "1.0.0",
  "description": "CodeForge AI CLI — autonomous coding agent in your terminal (like Claude Code + Codex)",
  "private": true,
  "type": "commonjs",
  "bin": {
    "codeforge": "./dist/index.js",
    "cf": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev":   "ts-node src/index.ts",
    "link":  "npm run build && npm link"
  },
  "dependencies": {
    "chalk":       "^4.1.2",
    "commander":   "^11.1.0",
    "inquirer":    "^8.2.6",
    "ora":         "^5.4.1",
    "node-fetch":  "^2.7.0",
    "dotenv":      "^16.4.5",
    "simple-git":  "^3.23.0",
    "glob":        "^10.3.12",
    "readline":    "^1.3.0"
  },
  "devDependencies": {
    "typescript":    "^5.3.3",
    "@types/node":   "^20.11.0",
    "@types/inquirer": "^8.2.10",
    "@types/node-fetch": "^2.6.11"
  }
}
